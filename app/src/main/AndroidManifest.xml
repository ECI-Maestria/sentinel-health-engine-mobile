            android:resizeableActivity="true"
            tools:targetApi="n" />

        <activity
            android:name=".ui.MainActivity"
            android:exported="false"
            android:resizeableActivity="true"
            tools:targetApi="n" />

        <service
            android:name=".MyFirebaseMessagingService"
            android:exported="false">
            <intent-filter>
                <action android:name="com.google.firebase.MESSAGING_EVENT" />
            </intent-filter>
        </service>

